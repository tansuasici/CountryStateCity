{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./countrystatecity-npm/dist",
    "rootDir": "./countrystatecity-npm/src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "module": "esnext",
    "target": "es2015",
    "lib": ["es2015", "dom"],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "strict": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["countrystatecity-npm/src/**/*"],
  "exclude": ["node_modules", "**/*.test.ts", "**/*.spec.ts"]
}
